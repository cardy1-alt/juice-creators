# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Admin email — the email that gets admin access (optional, defaults to admin@juicecreators.com)
VITE_ADMIN_EMAIL=admin@juicecreators.com

# Google Maps API key for address autocomplete on business signup (optional)
VITE_GOOGLE_MAPS_API_KEY=

# Enable demo mode via ?demo=creator|business|admin URL param (optional, defaults to disabled)
VITE_ENABLE_DEMO=false

# Resend API key for transactional emails (required for email sending)
RESEND_API_KEY=

# App URL used in email links (required for Edge Functions)
APP_URL=
