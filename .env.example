# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Admin email — the email that gets admin access (defaults to hello@nayba.app)
VITE_ADMIN_EMAIL=hello@nayba.app

# Enable demo mode via ?demo=creator|business|admin URL param (optional, defaults to disabled).
# WARNING: Demo mode bypasses authentication entirely — set to 'true' ONLY if you actively need
# it for brand demos. Users in demo mode see a persistent yellow banner so it can't be
# mistaken for a real session. Leave as 'false' for normal production deployments.
VITE_ENABLE_DEMO=false

# Server-side AI brief generation — set in Vercel env vars
ANTHROPIC_API_KEY=

# Supabase Edge Function secret — set in Supabase dashboard
RESEND_API_KEY=

# App URL used in email links (required for Edge Functions)
APP_URL=https://app.nayba.app

# Admin email for RLS policies — must match the value set via:
#   ALTER DATABASE postgres SET app.admin_email = '...';
ADMIN_EMAIL=hello@nayba.app

# Supabase service role key (required for Vercel cron → Edge Function calls, never expose client-side)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Vercel Cron secret (optional, auto-set by Vercel when crons are configured)
CRON_SECRET=

# Sentry DSN for error tracking (optional — errors logged to console if unset)
# Get from Sentry project → Settings → Client Keys (DSN)
VITE_SENTRY_DSN=

# Vercel Analytics needs no env vars — add it in Vercel dashboard → Analytics tab

# ── Bury Juice sponsor storefront ─────────────────────────────────
# Server-side Stripe keys (set in Vercel env, not committed).
# Hosted Stripe Checkout means no publishable key on the client.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Nine Stripe Price IDs for the tier × pack matrix
STRIPE_PRICE_CLASSIFIED_SINGLE=
STRIPE_PRICE_CLASSIFIED_PACK4=
STRIPE_PRICE_CLASSIFIED_PACK12=
STRIPE_PRICE_FEATURE_SINGLE=
STRIPE_PRICE_FEATURE_PACK4=
STRIPE_PRICE_FEATURE_PACK12=
STRIPE_PRICE_PRIMARY_SINGLE=
STRIPE_PRICE_PRIMARY_PACK4=
STRIPE_PRICE_PRIMARY_PACK12=

# Single admin password gate for /admin/sponsors
BJ_ADMIN_PASSWORD=

# Optional — Notion sponsor bookings DB sync
NOTION_TOKEN=
NOTION_BURY_JUICE_BOOKINGS_DB_ID=
